# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Patterns are unanchored so they apply inside any partN/ subproject.

# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# production
build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# vercel
.vercel

# supabase
**/supabase/.temp

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code skill symlinks created by `npx skills add` (point at
# .agents/skills/, the real committed content). Not tracked because this
# checkout has core.symlinks=false, so git would dereference them into
# duplicate copies instead of storing the symlink. Regenerate with
# `npx skills add supabase/agent-skills` after a fresh clone.
.claude/skills/supabase
.claude/skills/supabase-postgres-best-practices
